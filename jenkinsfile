pipeline {
    agent any

    environment {
        BRANCH = 'main'
    }

    parameters {
        string(name: 'ENV', defaultValue: 'dev', description: 'Deployment environment')
    }

    stages {

        stage('stage1 - Environment Variable') {
            agent { label 'slave1' }
            steps {
                echo "This stage is using environment variable"
                echo "Branch name is: ${BRANCH}"

                sh '''
                echo "Branch from shell: $BRANCH"
                '''
            }
        }

        stage('stage2 - Parameter') {
            steps {
                echo "This stage is using parameter"
                echo "Selected environment: ${params.ENV}"

                sh '''
                echo "Deployment environment: $ENV"
                '''
            }
        }

    }
}