pipeline {
    agent any
    
    stages {
        stage('Print AWS Username') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-cred'
                ]]) {
                    
                    sh '''
                    aws sts get-caller-identity --query Arn --output text
                    '''
                    
                }
            }
        }
    }
}